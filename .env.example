# Generated from fin_agent.bootstrap.settings.AppSettings.
# Regenerate with: fin-agent doctor --write-env-example .env.example

# Application name used by the API and CLI.
FIN_AGENT__APP__NAME=fin-agent

# Active configuration environment.
FIN_AGENT__APP__ENVIRONMENT=local

# Logging level for API and CLI commands.
FIN_AGENT__LOGGING__LEVEL=INFO

# Emit newline-delimited JSON logs instead of plain text.
FIN_AGENT__LOGGING__JSON=false

# Database connection string.
FIN_AGENT__DATABASE__URL=sqlite:///./var/fin_agent.db

# Echo SQL statements to logs.
FIN_AGENT__DATABASE__ECHO=false

# Default request timeout used by adapters and services.
FIN_AGENT__RUNTIME__REQUEST_TIMEOUT_SECONDS=30

# Directory for local runtime artifacts.
FIN_AGENT__RUNTIME__DATA_DIR=./var

# Validate required provider secrets during runtime bootstrap.
FIN_AGENT__RUNTIME__VALIDATE_RUNTIME_SECRETS=true

# Default LLM provider name.
FIN_AGENT__PROVIDERS__DEFAULT_SELECTION__LLM=openai

# Default market data provider name.
FIN_AGENT__PROVIDERS__DEFAULT_SELECTION__MARKET_DATA=yfinance

# Default search provider name.
FIN_AGENT__PROVIDERS__DEFAULT_SELECTION__SEARCH=exa

# Default workflow registered for research tasks.
FIN_AGENT__WORKFLOWS__DEFAULT_SELECTION__RESEARCH=research

# Enable public API docs endpoints.
FIN_AGENT__FEATURE_FLAGS__ENABLE_API_DOCS=true

# Persist workflow traces in the runtime store.
FIN_AGENT__FEATURE_FLAGS__ENABLE_TRACE_STORAGE=true

# OpenAI model used for research workflows.
FIN_AGENT__OPENAI__MODEL=gpt-4.1-mini

# OpenAI API key for the active LLM provider.
FIN_AGENT__OPENAI__API_KEY=<set-me>

# Optional custom OpenAI-compatible base URL.
FIN_AGENT__OPENAI__BASE_URL=

# Provider-level timeout for OpenAI requests.
FIN_AGENT__OPENAI__TIMEOUT_SECONDS=30

# Sampling temperature for LLM calls.
FIN_AGENT__OPENAI__TEMPERATURE=0.1

# Historical data window used by the default market data adapter.
FIN_AGENT__MARKET_DATA__HISTORY_PERIOD=1y

# Provider-level timeout for market data lookups.
FIN_AGENT__MARKET_DATA__REQUEST_TIMEOUT_SECONDS=15

# Enable the market data adapter.
FIN_AGENT__MARKET_DATA__ENABLED=true

# Price adjustment method: qfq=前复权, hfq=后复权, ''=不复权.
FIN_AGENT__AKSHARE__ADJUST=qfq

# Historical data window used by the AKShare market data adapter.
FIN_AGENT__AKSHARE__HISTORY_PERIOD=1y

# Provider-level timeout for AKShare data lookups.
FIN_AGENT__AKSHARE__REQUEST_TIMEOUT_SECONDS=15

# Enable the AKShare market data adapter.
FIN_AGENT__AKSHARE__ENABLED=true

# Maximum number of search results returned by the default search adapter.
FIN_AGENT__SEARCH__MAX_RESULTS=8

# Search provider API key.
FIN_AGENT__SEARCH__API_KEY=<set-me>

# Include full text snippets in search responses.
FIN_AGENT__SEARCH__INCLUDE_TEXT=true

# Enable the search adapter.
FIN_AGENT__SEARCH__ENABLED=true

# Maximum number of tool calls allowed in one research run.
FIN_AGENT__RESEARCH_WORKFLOW__MAX_TOOL_CALLS=6

# Maximum workflow iterations before the run is terminated.
FIN_AGENT__RESEARCH_WORKFLOW__MAX_ITERATIONS=4

# Maximum number of evidence records surfaced in the final report.
FIN_AGENT__RESEARCH_WORKFLOW__EVIDENCE_LIMIT=12

# Run the review stage before persisting a report.
FIN_AGENT__RESEARCH_WORKFLOW__ENABLE_REVIEW=true
